classDiagram
    class Animal {
        +String name
        +int age
        +makeSound() void
    }
    class Dog {
        +String breed
        +fetch() void
    }
    class Cat {
        +bool indoor
        +purr() void
    }
    class Shelter {
        +List~Animal~ animals
        +adopt(Animal) bool
        +intake(Animal) void
    }

    Animal <|-- Dog
